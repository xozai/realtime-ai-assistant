OPENAI_API_KEY=your_key_here
STORY_GENERATION_MODEL=gpt-4o
# Voice mode: install sounddevice (pip install sounddevice) and run with --voice flag
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USER_EMAIL=you@example.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_STORY_POINTS_FIELD=story_points
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
# Confluence export (reuses JIRA_BASE_URL + JIRA credentials by default)
CONFLUENCE_BASE_URL=
CONFLUENCE_SPACE_KEY=your_space_key
